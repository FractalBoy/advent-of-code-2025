{
    "name": "C++",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "workspaceMount": "",
    "remoteUser": "vscode",
    "containerEnv": {
        "HOME": "/home/vscode"
    },
    "runArgs": [
        "--userns=keep-id",
        "--volume=${localWorkspaceFolder}:/workspaces/${localWorkspaceFolderBasename}:Z"
    ]
}